rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Role Helpers
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isConsultant() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'consultant';
    }
    function isContractor() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'contractor';
    }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return (!('email' in data) || (data.email is string && data.email.size() <= 200)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('role' in data) || (data.role in ['admin', 'contractor', 'consultant'])) &&
             (!('userId' in data) || data.userId == request.auth.uid) &&
             (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2000)) &&
             (!('photoUrl' in data) || data.photoUrl == null || (data.photoUrl is string && data.photoUrl.size() <= 2000)) &&
             (!('createdAt' in data) || data.createdAt == request.time);
    }
    function isValidMaterial(data) {
      return (!('division' in data) || (data.division is string && data.division.size() <= 100)) &&
             (!('description' in data) || (data.description is string && data.description.size() <= 5000)) &&
             (!('status' in data) || (data.status is string && data.status.size() <= 100)) &&
             (!('priority' in data) || (data.priority in ['HIGH', 'MEDIUM', 'LOW'])) &&
             (!('quantity' in data) || (data.quantity is number || data.quantity is int)) &&
             (!('activityId' in data) || (data.activityId is string && data.activityId.size() <= 100)) &&
             (!('supplier' in data) || (data.supplier is string && data.supplier.size() <= 500)) &&
             (!('unit' in data) || (data.unit is string && data.unit.size() <= 100)) &&
             (!('location' in data) || (data.location is string && data.location.size() <= 500)) &&
             (!('jobId' in data) || (data.jobId is string && data.jobId.size() <= 128)) &&
             (!('sortOrder' in data) || (data.sortOrder is number || data.sortOrder is int)) &&
             (!('rev' in data) || (data.rev is string && data.rev.size() <= 20)) &&
             (!('boqRef' in data) || (data.boqRef is string && data.boqRef.size() <= 100)) &&
             (!('poStatus' in data) || (data.poStatus is string && data.poStatus.size() <= 100)) &&
             (!('responsible' in data) || (data.responsible is string && data.responsible.size() <= 100)) &&
             (!('nextAction' in data) || (data.nextAction is string && data.nextAction.size() <= 500)) &&
             (!('irDwgStatus' in data) || (data.irDwgStatus is string && data.irDwgStatus.size() <= 100)) &&
             (!('irRef' in data) || (data.irRef is string && data.irRef.size() <= 200)) &&
             (!('boqAmount' in data) || (data.boqAmount is number || data.boqAmount is int)) &&
             (!('dateSubmitted' in data) || (data.dateSubmitted is string && data.dateSubmitted.size() <= 100)) &&
             (!('dateApproved' in data) || (data.dateApproved is string && data.dateApproved.size() <= 100)) &&
             (!('mockupRequired' in data) || (data.mockupRequired is string && data.mockupRequired.size() <= 200)) &&
             (!('irDwgRequired' in data) || (data.irDwgRequired is string && data.irDwgRequired.size() <= 200)) &&
             (!('finishCode' in data) || (data.finishCode is string && data.finishCode.size() <= 200));
    }

    function isValidHistory(data) {
      return data.status is string && data.status.size() <= 100 &&
             data.updatedBy is string && data.updatedBy.size() <= 200 &&
             (!('comment' in data) || (data.comment is string && data.comment.size() <= 2000)) &&
             data.timestamp == request.time;
    }

    function isValidJob(data) {
      return (!('name' in data) || (data.name is string && data.name.size() <= 200)) &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('status' in data) || (data.status in ['active', 'completed', 'on-hold'])) &&
             (!('createdAt' in data) || data.createdAt == request.time) &&
             (!('updatedAt' in data) || data.updatedAt == request.time);
    }

    // 3. Collection Rules
    
    // User Profiles
    match /users/{userId} {
      // Identity check first to avoid recursion or heavy reads
      allow get: if isSignedIn() && request.auth.uid == userId;
      // Then other checks
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && 
                      incoming().keys().hasAll(['email', 'displayName', 'role', 'userId']) &&
                      isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'photoUrl']); // Supporting both case variations if needed
      allow update, delete: if isAdmin();
    }
    
    // Materials: The Core Registry
    match /materials/{materialId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(materialId);
      
      allow create: if (isAdmin() || isContractor()) && isSignedIn() && isValidId(materialId) && 
                      incoming().keys().hasAll(['division', 'description', 'status', 'priority', 'quantity']) &&
                      isValidMaterial(incoming()) && incoming().createdAt == request.time;
      
      allow update: if isSignedIn() && isValidId(materialId) && (
        (isAdmin() || isContractor() || isConsultant()) &&
        isValidMaterial(incoming()) && 
        incoming().createdAt == existing().createdAt &&
        incoming().updatedAt == request.time
      );
      allow delete: if isAdmin();

      // Sub-collection: History Logs
      match /history/{historyId} {
        allow list: if isSignedIn();
        allow create: if isSignedIn() && isValidId(historyId) && isValidHistory(incoming());
        allow update: if isSignedIn() && isValidId(historyId) &&
                     existing().timestamp > request.time - duration.value(48, 'h') &&
                     incoming().diff(existing()).affectedKeys().hasOnly(['comment', 'lastEditedAt']) &&
                     incoming().comment is string && incoming().comment.size() <= 2000;
        allow delete: if isAdmin();
      }

      // Sub-collection: Audit Logs
      match /auditLog/{auditId} {
        allow list, get: if isSignedIn();
        allow create: if isSignedIn() && isValidId(auditId);
        allow delete: if isAdmin();
      }
    }

    // Collection Group Access
    match /{path=**}/auditLog/{auditId} {
      allow read: if isSignedIn();
    }

    // Jobs Collection
    match /jobs/{jobId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(jobId);
      allow create: if isAdmin() && isSignedIn() && isValidId(jobId) && 
                      incoming().keys().hasAll(['name', 'status']) &&
                      isValidJob(incoming());
      allow update: if isAdmin() && isSignedIn() && isValidId(jobId) && isValidJob(incoming());
      allow delete: if isAdmin() && isSignedIn() && isValidId(jobId);
    }

    // Time Logs Collection
    match /timelogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(logId) && incoming().userId == request.auth.uid && (incoming().clockIn is timestamp || incoming().clockIn == request.time);
      allow update: if isSignedIn() && isValidId(logId) && existing().userId == request.auth.uid && 
                   incoming().diff(existing()).affectedKeys().hasOnly(['clockOut', 'durationMinutes', 'notes']);
      allow delete: if isAdmin();
    }

    // Admin Access
    match /admins/{adminId} {
      allow read: if isSignedIn();
    }

    // Global Settings
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Connectivity Test
    match /test/connection {
      allow get: if true;
    }
  }
}
